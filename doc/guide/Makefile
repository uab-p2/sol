SITE_DIR = site
MKDOCS = mkdocs

.PHONY: all build serve clean rebuild doctor help campaign_pages

all: build

build: campaign_pages

campaign_pages:
	@for tag_name in $(shell python3 ../tool/tag.py tag); do \
  		echo "<!-- autogenerated by guide build -->" > sections/campaign_$$tag_name.md; \
		echo "# {{ tag_title(\"$$tag_name\") }}" >> sections/campaign_$$tag_name.md; \
		echo "" >> sections/campaign_$$tag_name.md; \
		echo "{{ tag_description(\"$$tag_name\") }}" >> sections/campaign_$$tag_name.md; \
		echo "" >> sections/campaign_$$tag_name.md; \
		echo "## Quests" >> sections/campaign_$$tag_name.md; \
		echo "" >> sections/campaign_$$tag_name.md; \
		echo "{{ tag_quests(\"$$tag_name\") }}" >> sections/campaign_$$tag_name.md; \
		echo "" >> sections/campaign_$$tag_name.md; \
	done
	$(MKDOCS) build

serve:
	$(MKDOCS) serve

clean:
	rm -rf $(SITE_DIR)

rebuild: clean build

doctor:
	$(MKDOCS) build --strict

help:
	@echo "Available commands:"
	@echo "  make build    - build static site"
	@echo "  make serve    - start dev server"
	@echo "  make clean    - remove site/"
	@echo "  make rebuild  - clean + build"
	@echo "  make doctor   - strict validation build"
